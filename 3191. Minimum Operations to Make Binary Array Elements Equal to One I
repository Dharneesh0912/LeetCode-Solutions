class Solution {
    public int minOperations(int[] nums) {
        int count = 0;

        for (int i = 0; i <= nums.length - 3; i++) {
            if (nums[i] == 0) {
                for (int j = 0+i; j < 3+i; j++) {
                    if(nums[j]==0){
                        nums[j]=1;
                    }
                    else if(nums[j]==1){
                        nums[j]=0;
                    } 
                }
                count++;
            }
        }
        for (int num : nums) {
            if (num == 0) {
                return -1;
            }
        }

        return count;
    }
}
