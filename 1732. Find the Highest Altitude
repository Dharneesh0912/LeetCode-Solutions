class Solution {
    public int largestAltitude(int[] gain) {
        int ans[]=new int[gain.length+1];
        ans[0]=0;
        for(int i=0;i<gain.length;i++){
            ans[i+1]=ans[i]+gain[i];
        }
        int max=0;
        for(int j=0;j<ans.length;j++){
            if(ans[j]>0 && ans[j]>max){
                max=ans[j];
            }

        }
        return max;
        
    }
}
