class Solution {
    public int averageValue(int[] nums) {
        ArrayList<Integer> list = new ArrayList<>();
        for (int num : nums) {
            if (num % 2 == 0 && num % 3 == 0) {
                list.add(num);
            }
        }
        if (list.size() == 0) {
            return 0;
        }
        int sum = 0;
        for (int val : list) {
            sum += val;
        }
        return sum / list.size(); 
    }
}
