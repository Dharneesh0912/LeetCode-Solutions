class Solution {
    public char nextGreatestLetter(char[] letters, char target) {
        char max=target;
        Arrays.sort(letters);
        for(int i=0;i<letters.length;i++){
            if(letters[i]>max){
                max=letters[i];
                return max;
            }
        }
        return letters[0];
        
    }
}
