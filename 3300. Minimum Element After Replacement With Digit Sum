class Solution {
    public int minElement(int[] nums) {
        int arr[]=new int[nums.length];
        for(int i=0;i<nums.length;i++){
            int num=nums[i];
            int sum=0;
            while(num!=0){
                sum=sum+num%10;
                num=num/10;
            }
            arr[i]=sum;
        }
        Arrays.sort(arr);
        return arr[0];
    }
}
