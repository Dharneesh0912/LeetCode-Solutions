class Solution {
    public int singleNumber(int[] nums) {
        if (nums.length == 1) {
            return nums[0]; 
        }
        
        int[] arr = new int[nums.length];
        
        for (int i = 0; i < nums.length; i++) {
            int count = 0;  
            for (int j = 0; j < nums.length; j++) {
                if (nums[i] == nums[j]) {
                    count++;
                }
            }
            arr[i] = count;  
        }
        
        for (int i = 0; i < arr.length; i++) {
            if (arr[i] == 1) {
                return nums[i]; 
            }
        }
        
        return 0;  
    }
}
