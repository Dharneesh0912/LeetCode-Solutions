class Solution {
    public int[] shuffle(int[] nums, int n) {
        int arr[]=new int[nums.length];
        int size=nums.length/2;
        int k=0;
        for(int i=0;i<nums.length;i=i+2){
            arr[i]=nums[k];
            k++;
        }
        for(int j=1;j<nums.length;j=j+2){
            arr[j]=nums[n];
            n++;
        }

        return arr;
        
    }
}
