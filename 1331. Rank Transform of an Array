class Solution {
    public int[] arrayRankTransform(int[] arr) {
        HashMap<Integer,Integer> map=new HashMap<>();
        int count=1;
        int ne[]=new int[arr.length];
        for(int i=0;i<arr.length;i++){
            ne[i]=arr[i];
        }
        Arrays.sort(arr);
        int ans[]=new int[arr.length];
        for(int i=0;i<arr.length;i++){
            if(!map.containsKey(arr[i])){
                map.put(arr[i],count);
                count++;
            }
        }
        for(int i=0;i<arr.length;i++){
            ans[i]=map.get(ne[i]);
        }
        return ans;
        
    }
}
