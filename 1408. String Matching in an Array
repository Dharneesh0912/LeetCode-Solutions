class Solution {
    public List<String> stringMatching(String[] words) {
        TreeSet<String> lst=new TreeSet<>();
        List<String> arr=new ArrayList<>();
        for(int i=0;i<words.length;i++){
            for(int j=0;j<words.length;j++){
                if(i!=j){
                    if(words[i].contains(words[j])){
                        lst.add(words[j]);
                    }
                }
            }
        }
        for(String s:lst){
            arr.add(s);    
        }
        return arr; 
    }
}
